{$WEB_HOST} {
  encode gzip zstd

  # Override upstream Cache-Control for static assets
  @static path *.mp4 *.webm *.webp *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff2 *.woff *.ttf
  header @static {
    Cache-Control "public, max-age=31536000, immutable"
    defer
  }

  @bundles path /_next/static/*
  header @bundles {
    Cache-Control "public, max-age=31536000, immutable"
    defer
  }

  reverse_proxy web:3000
}

{$VOICE_HOST} {
  encode gzip zstd
  reverse_proxy voice:3001
}
